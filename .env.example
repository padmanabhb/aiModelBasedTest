# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# Flask Settings
# ============================================================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================================
# LLM Integration - Multiple LLM Provider Support
# ============================================================================
# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# Claude (Anthropic) Configuration
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Default LLM Provider ('openai' or 'claude')
# The application will automatically fall back to an alternative provider if primary is unavailable
DEFAULT_LLM_PROVIDER=openai

# ============================================================================
# Server Settings
# ============================================================================
HOST=0.0.0.0
PORT=5000

# ============================================================================
# Additional Settings
# ============================================================================
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# ============================================================================
# Setup Notes
# ============================================================================
# 1. At minimum, configure ONE LLM provider (OpenAI or Claude)
# 2. For resilience and automatic failover, configure both providers
# 3. The application gracefully handles missing providers with intelligent fallback analysis
# 4. Never commit this file with real API keys to version control
